generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Учётная запись админки (аутентификацию можно добавить позже: сессии, argon2 и т.д.).
model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

/// Подпись точки маршрута (панорама): кнопки перехода и блок «зона — название».
model SceneCopy {
  sceneId String @id
  title   String
  updatedAt DateTime @updatedAt
}

/// Название зоны и подпись диапазона на карте.
model ZoneCopy {
  zoneKey  String @id
  title    String
  mapRange String @default("")
  updatedAt DateTime @updatedAt
}

/// Произвольные строки интерфейса (ключ → текст).
model SiteCopy {
  key   String @id
  value String
  updatedAt DateTime @updatedAt
}
