# Скопируй в `.env` и при необходимости поправь.
# Путь к SQLite относительно папки `prisma/` (файл будет `prisma/dev.db`).
DATABASE_URL="file:./dev.db"
ADMIN_API_PORT=4000
ADMIN_CORS_ORIGIN="http://localhost:5173"
# Обязателен для PUT /api/admin/copy и поля токена в админке
ADMIN_TOKEN="замени-на-секретную-строку"
