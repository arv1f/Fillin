  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:force": "vite --force",
    "dev:all": "concurrently -n web,api -c cyan,magenta \"npm run dev\" \"npm run server:dev\"",
    "server:dev": "tsx watch server/index.ts",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
